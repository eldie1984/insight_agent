# OpenRouter API key for the LLM
# Get from: https://openrouter.ai/keys
# OpenRouter provides access to Claude, GPT, and other models
OPENROUTER_API_KEY=sk-or-...

# Optional: Set which model to use (default: openai/gpt-3.5-turbo - cheap & reliable)
# Other options:
#   - anthropic/claude-3.5-sonnet (paid, high quality)
#   - openai/gpt-4-turbo (paid, better reasoning)
#   - openrouter/auto (cheapest available)
#   - mistralai/mistral-7b-instruct (free/cheap)
# OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Google Cloud configuration
GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1

# BigQuery configuration
BIGQUERY_DATASET=sales_data  # [ASSUMPTION A4] — confirm actual dataset name
BIGQUERY_TABLE=sales_fact_table  # [ASSUMPTION A4] — confirm actual table name

# Forecast model service endpoint
FORECAST_MODEL_ENDPOINT=https://licor-forecaster-XXXXX.us-central1.run.app/predict_array  # [ASSUMPTION A1] — confirm prod URL

# FastAPI
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Development settings
ENVIRONMENT=development  # Set to 'production' for Cloud Run

# LangSmith Observability (optional)
LANGSMITH_TRACING=true  # Set to 'true' to enable LangSmith tracing
LANGSMITH_API_KEY=lsv_...  # Get from https://smith.langchain.com
LANGSMITH_PROJECT=sales-assistant-agent  # Project name in LangSmith
